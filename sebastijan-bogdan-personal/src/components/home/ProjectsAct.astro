---
import type { ProjectsSection } from "../../content/homeContent";
import ProjectsAssemblyDiagram from "./ProjectsAssemblyDiagram.astro";

interface Props {
  content: ProjectsSection;
}

const { content } = Astro.props;
---

<section id="act-projects" class="home-act act-projects" data-act="projects">
  <div class="act-panel act-panel-projects" data-scene-panel>
    <div class="projects-scene" data-project-stage data-project-scene>
      <header class="act-header act-header-projects">
        <p class="act-kicker" data-reveal>{content.actTitle}</p>
        <h2 class="act-title" data-reveal>{content.heading}</h2>
        <p class="act-intro" data-reveal>{content.intro}</p>
      </header>

      <div class="projects-assembly-field" data-project-field aria-hidden="true">
        <ProjectsAssemblyDiagram className="projects-assembly-diagram" />
      </div>

      <div class="project-spec-layer">
        {content.stations.map((station, index) => (
          <article
            class={`project-spec-panel project-spec-panel-${station.id}`}
            data-project-panel
            data-project-mode={station.id}
            data-node
            style={`--project-index:${index};`}
          >
            <p class="project-panel-kicker">Subsystem 0{index + 1}</p>
            <h3>{station.title}</h3>
            <p class="project-panel-body">{station.body}</p>
            <ul>
              {station.bullets.map((bullet) => (
                <li>{bullet}</li>
              ))}
            </ul>
            <p class="project-motif">{station.motif}</p>
            <div class="project-tags" aria-label={`${station.title} stack`}>
              {station.tags.map((tag) => (
                <span>{tag}</span>
              ))}
            </div>
          </article>
        ))}
      </div>

      <ol class="project-mode-track" aria-hidden="true">
        <li data-project-dot></li>
        <li data-project-dot></li>
        <li data-project-dot></li>
      </ol>
    </div>
  </div>
</section>
