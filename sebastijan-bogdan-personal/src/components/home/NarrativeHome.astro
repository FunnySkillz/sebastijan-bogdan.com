---
import "../../styles/home.css";
import type { HomeLocale, HomePageContent } from "../../content/homeContent";
import HeroAct from "./HeroAct.astro";
import ExperienceAct from "./ExperienceAct.astro";
import ProjectsAct from "./ProjectsAct.astro";
import NarrativeStage from "./NarrativeStage.astro";
import ToolboxAct from "./ToolboxAct.astro";
import PhilosophyAct from "./PhilosophyAct.astro";
import ContactAct from "./ContactAct.astro";

interface Props {
  locale: HomeLocale;
  content: HomePageContent;
}

const { locale, content } = Astro.props;
---

<div class="home-narrative home-narrative-directed" data-home-root data-locale={locale}>
  <NarrativeStage content={content} />
  <HeroAct content={content.hero} />
  <ExperienceAct content={content.experience} />
  <ProjectsAct content={content.projects} />
  <ToolboxAct content={content.toolbox} />
  <PhilosophyAct content={content.philosophy} />
  <ContactAct content={content.contact} />
</div>

<script>
  import { initHomeScrollAnimations } from "../../scripts/useHomeScrollAnimations";

  const root = document.querySelector("[data-home-root]");

  if (root instanceof HTMLElement) {
    const motionQuery = window.matchMedia("(prefers-reduced-motion: reduce)");
    const getBreakpoint = () => {
      if (window.innerWidth >= 1080) return "desktop";
      if (window.innerWidth >= 768) return "tablet";
      return "mobile";
    };

    let currentBreakpoint = getBreakpoint();
    let animationHandle = initHomeScrollAnimations({
      root,
      reducedMotion: motionQuery.matches,
      breakpoint: currentBreakpoint
    });

    const reinitialize = () => {
      animationHandle.destroy();
      currentBreakpoint = getBreakpoint();
      animationHandle = initHomeScrollAnimations({
        root,
        reducedMotion: motionQuery.matches,
        breakpoint: currentBreakpoint
      });
    };

    const onPageHide = () => {
      animationHandle.destroy();
      motionQuery.removeEventListener("change", onMotionChange);
      window.removeEventListener("resize", onResize);
    };
    const onMotionChange = () => reinitialize();

    let resizeTimer = 0;
    const onResize = () => {
      window.clearTimeout(resizeTimer);
      resizeTimer = window.setTimeout(() => {
        const nextBreakpoint = getBreakpoint();
        if (nextBreakpoint !== currentBreakpoint) {
          reinitialize();
        }
      }, 180);
    };

    window.addEventListener("pagehide", onPageHide, { once: true });
    motionQuery.addEventListener("change", onMotionChange);
    window.addEventListener("resize", onResize);
  }
</script>
