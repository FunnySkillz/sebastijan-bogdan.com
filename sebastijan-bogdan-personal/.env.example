# Core contact delivery
RESEND_API_KEY=
CONTACT_TO_EMAIL=
CONTACT_FROM_EMAIL=

# Cloudflare Turnstile
TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# Optional if you prefer public env variable naming in Astro templates
PUBLIC_TURNSTILE_SITE_KEY=

# Upstash rate limiting
UPSTASH_REDIS_REST_URL="test.com"
UPSTASH_REDIS_REST_TOKEN=testToken123123123123

# Search telemetry
GOOGLE_SITE_VERIFICATION=
PUBLIC_GOOGLE_SITE_VERIFICATION=

# Optional legal/contact fallback display
PUBLIC_CONTACT_EMAIL=
